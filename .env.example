# FlyBy configuration — copy this file to .env and fill in your details:
#   cp .env.example .env

# Your location (Apple Maps: right-click → "Copy Coordinates")
HOME_LAT=51.4700
HOME_LON=-0.4543

# Notify/display planes within this many km
RADIUS_KM=8

# How often to poll, in seconds (keep >= 15 to be polite to FlightRadar24)
POLL_SECONDS=20

# Local HTTP port for the /touchbar and /status endpoints
PORT=8787

# Fetch full aircraft model + airport names for the nearest/new flights
ENRICH_DETAILS=true

# Optional: use a built-in macOS sound (Glass, Hero, Submarine, …)
# instead of the bundled cabin chime.
# NOTIFY_SOUND=Glass
