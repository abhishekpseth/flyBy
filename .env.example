# FlyBy configuration — copy this file to .env and fill in your details:
#   cp .env.example .env

# Your location (Apple Maps: right-click → "Copy Coordinates")
HOME_LAT=51.4700
HOME_LON=-0.4543

# Notify/display planes within this many km
RADIUS_KM=15

# How often to poll, in seconds. OpenSky is the primary source; a free account
# gets 4000 credits/day, so keep this >= 22s (86400/4000) to stay in budget.
POLL_SECONDS=30

# Local HTTP port for the /touchbar and /status endpoints
PORT=8787

# Enrich the nearest/new flights with route + aircraft model from FlightRadar24.
# FR24 is only called when a plane is actually in range, so it never gets throttled.
ENRICH_DETAILS=true

# OpenSky OAuth2 credentials — strongly recommended.
# Free registration -> 4000 credits/day (anonymous is only 400/day and will run
# out within hours of polling). Create an API client at:
#   https://opensky-network.org/  ->  My OpenSky  ->  Account  ->  API clients
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# Optional: use a built-in macOS sound (Glass, Hero, Submarine, …)
# instead of the bundled cabin chime.
# NOTIFY_SOUND=Glass
